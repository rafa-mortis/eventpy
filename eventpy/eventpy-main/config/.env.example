SECRET_KEY=your-secret-key-here-change-this-in-production
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Configuração da Base de Dados
# Opções: sqlite, mysql, sqlserver
DB_TYPE=sqlite

# Configurações MySQL (se DB_TYPE=mysql)
MYSQL_DATABASE=reciclagem_reee
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Configurações SQL Server (se DB_TYPE=sqlserver)
SQLSERVER_DATABASE=reciclagem_reee
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=your_password
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
